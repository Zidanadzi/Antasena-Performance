{
  "expo": {
    "name": "Antasena Performance",
    "slug": "antasena-project",
    "owner": "ziddan17s-organization",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.antasena.performance",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Antasena Performance needs Bluetooth access to connect to your ECU for real-time telemetry and tuning.",
        "NSBluetoothPeripheralUsageDescription": "Antasena Performance needs Bluetooth access to connect to your ECU.",
        "NSLocationWhenInUseUsageDescription": "Antasena Performance needs Location access to track race metrics and GPS speed."
      }
    },
    "android": {
      "package": "com.antasena.performance",
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 23
          }
        }
      ],
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "modes": [
            "peripheral",
            "central"
          ],
          "bluetoothAlwaysPermission": "Allow Antasena Performance to connect to your ECU."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow Antasena Performance to use your location."
        }
      ],
      "react-native-bluetooth-classic"
    ],
    "extra": {
      "eas": {
        "projectId": "15ceb7c4-349a-46ba-8f74-799059d600e5"
      }
    }
  }
}
