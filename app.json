{
  "expo": {
    "name": "Antasena Performance",
    "slug": "antasena-performance",
    "owner": "zidanadzi17s-organization",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.antasena.performance",
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow Antasena Performance to use your location for race metrics."
        }
      ],
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "modes": [
            "scan",
            "connect"
          ],
          "bluetoothAlwaysPermission": "Allow Antasena Performance to use Bluetooth to connect to your ECU."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d2e87669-f65e-4d82-a3cd-2497c088f867"
      }
    }
  }
}
