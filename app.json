{
  "expo": {
    "name": "Antasena Performance",
    "slug": "antasena-performance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.antasena.performance"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow Antasena Performance to use your location for race metrics."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d2e87669-f65e-4d82-a3cd-2497c088f867"
      }
    }
  }
}
